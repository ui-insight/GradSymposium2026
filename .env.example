# ── Database ──────────────────────────────────────────────────────────
GPSA_DATABASE_URL=postgresql+asyncpg://gpsa:gpsa@db:5432/gpsa

# ── Security ──────────────────────────────────────────────────────────
GPSA_SECRET_KEY=change-me-to-a-random-secret
GPSA_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── CORS ──────────────────────────────────────────────────────────────
GPSA_CORS_ORIGINS=http://localhost:8080

# ── Dev mode (set to false in production) ─────────────────────────────
GPSA_DEV_MODE=true

# ── Docker Compose ────────────────────────────────────────────────────
HOST_PORT=8080
POSTGRES_USER=gpsa
POSTGRES_PASSWORD=gpsa
POSTGRES_DB=gpsa
